#!/usr/bin/env bash

set -eu

# Expects extension/manifest.json version to have been incremented, by running `npm version <level>`,
# which would have triggered scripts/postversion
version_number=$(jq '.version' -r < extension/manifest.json)

npm run lint
npm run build
git push origin main
git push --tags

archive_name=time-capsule-v${version_number}
mkdir $archive_name
cp -r README.md \
  extension \
  img \
  package-lock.json \
  package.json \
  rollup.config.js \
  scripts \
  src \
  $archive_name

zip -r v${version_number}.zip $archive_name
mv v${version_number}.zip ./code_archive/
mv $archive_name /tmp/$archive_name-$RANDOM

echo "Now you would need to upload ./web-ext-artifacts/website_history_browser-${version_number}.zip
to https://addons.mozilla.org/fr/developers/addon/website-history-browser/versions/submit/"
echo "It will also ask you for the source code: you can then upload ./code_archive/v${version_number}.zip"
